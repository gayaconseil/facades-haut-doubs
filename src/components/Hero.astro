---
interface Props {
  titre?: string;
  sousTitre?: string;
  bgImage?: string;
  marque?: string;
}

const {
  titre = 'Soyez serein à l\'intérieur,<br><em>rénovez votre extérieur</em>',
  sousTitre = 'Façades Haut-Doubs accompagne les particuliers et les professionnels du Haut-Doubs dans la rénovation, l\'isolation et le bardage de leurs façades depuis 18 ans.',
  bgImage = '/photos-fhd/hero-chateau-joux-02.jpg',
  marque,
} = Astro.props;
---

<section class="hero" style={`background-image: linear-gradient(rgba(0,0,0,0.55), rgba(0,0,0,0.65)), url('${bgImage}');`}>
  <div class="container">
    <div class="hero-content">
      {marque && <p class="hero-marque" set:html={marque}></p>}
      <h1 set:html={titre}></h1>
      <p class="hero-sub">{sousTitre}</p>
      <div class="hero-cta">
        <a href="#devis" class="btn">Demander un devis gratuit</a>
        <a href="#devis" class="btn btn-outline-light">
          <svg class="phone-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          03 XX XX XX XX
        </a>
      </div>

      <div class="hero-opening">
        <div class="opening-pulse"></div>
        <div class="opening-content">
          <span class="opening-label">Nouvelle agence Haut-Doubs</span>
          <span class="opening-date">Ouverture le 1<sup>er</sup> mars 2027</span>
          <span class="opening-meta">Rue Gay Lussac · ZAC En Pougie · 25800 Valdahon</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 70px 0 50px;
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    overflow: hidden;
    min-height: calc(100vh - 96px);
    display: flex;
    align-items: center;
  }

  .hero-content {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
    color: white;
  }

  .hero-marque {
    font-family: var(--font-titre);
    font-size: clamp(2.6rem, 6vw, 4.6rem);
    color: white;
    margin-bottom: 10px;
    line-height: 1.05;
    text-shadow: 0 2px 20px rgba(0,0,0,0.45);
    letter-spacing: 0.5px;
  }
  .hero-marque :global(.o) { color: var(--orange-300); }

  .hero h1 {
    font-size: clamp(1.35rem, 2.8vw, 2.1rem);
    margin-bottom: 14px;
    color: rgba(255,255,255,0.95);
    text-shadow: 0 2px 16px rgba(0,0,0,0.4);
    line-height: 1.25;
    font-weight: 400;
  }
  .hero h1 :global(em) {
    color: var(--orange-300);
    font-style: normal;
  }

  .hero-sub {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.92);
    max-width: 680px;
    margin: 0 auto 22px;
    text-shadow: 0 1px 8px rgba(0,0,0,0.3);
    line-height: 1.5;
  }

  /* Bouton outline pour fond sombre */
  :global(.btn-outline-light) {
    background: transparent;
    border: 2px solid white;
    color: white;
    padding: 12px 26px;
    font-family: var(--font-corps);
    font-weight: 600;
    font-size: 1rem;
    border-radius: 6px;
    text-decoration: none;
    display: inline-block;
    transition: background 0.2s;
  }
  :global(.btn-outline-light:hover) {
    background: rgba(255,255,255,0.15);
    color: white;
  }

  .hero-cta {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 48px;
  }
  :global(.btn-outline-light) {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .phone-icon {
    width: 19px;
    height: 19px;
    color: white;
    flex-shrink: 0;
  }

  .hero-opening {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    background: rgba(244, 101, 47, 0.2);
    border: 2px solid var(--orange-500);
    backdrop-filter: blur(6px);
    padding: 12px 22px;
    border-radius: 12px;
    margin-top: 0;
    box-shadow: 0 8px 32px rgba(244, 101, 47, 0.25);
  }
  .opening-pulse {
    width: 14px;
    height: 14px;
    background: var(--orange-500);
    border-radius: 50%;
    position: relative;
    flex-shrink: 0;
    box-shadow: 0 0 0 0 var(--orange-500);
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(244, 101, 47, 0.7); }
    70% { box-shadow: 0 0 0 14px rgba(244, 101, 47, 0); }
    100% { box-shadow: 0 0 0 0 rgba(244, 101, 47, 0); }
  }
  .opening-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
  }
  .opening-label {
    font-size: 0.78rem;
    color: var(--orange-300);
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 700;
  }
  .opening-date {
    font-family: var(--font-titre);
    font-size: 1.3rem;
    color: white;
    line-height: 1.1;
    margin: 2px 0;
  }
  .opening-date sup {
    font-size: 0.7em;
    vertical-align: super;
  }
  .opening-meta {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.85);
  }

  @media (max-width: 640px) {
    .hero-opening { padding: 14px 20px; gap: 12px; }
    .opening-date { font-size: 1.2rem; }
    .opening-label { font-size: 0.7rem; }
    .opening-meta { font-size: 0.75rem; }
  }
  @media (max-width: 768px) {
    .hero { background-attachment: scroll; }
  }

  @media (max-width: 640px) {
    .hero { padding: 60px 0 50px; }
    .hero-trust { gap: 24px; }
    .trust-num { font-size: 1.6rem; }
  }
</style>
