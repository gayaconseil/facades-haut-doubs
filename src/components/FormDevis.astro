---
interface Props {
  titre?: string;
  sousTitre?: string;
  pageName?: string;
}

const {
  titre = 'Demandez votre étude personnalisée',
  sousTitre = 'Décrivez-nous votre projet, nous vous recontactons sous 24h ouvrées.',
  pageName,
} = Astro.props;

const pageSource = Astro.url.pathname;

// Libellé lisible de la page d'origine (pour identifier le formulaire à la réception)
const SEG: Record<string, string> = {
  'isolation-thermique-exterieur': 'Isolation thermique par l\'extérieur',
  'ravalement-de-facade': 'Ravalement de façade',
  'bardage-exterieur': 'Bardage extérieur',
  'enduit-de-facade': 'Enduit de façade',
  'etancheite-de-sol': 'Étanchéité de sol',
  'nos-services': 'Nos services',
  'choisir-ses-materiaux': 'Choisir ses matériaux',
  'nos-references': 'Nos références',
  'nos-valeurs': 'Nos valeurs',
  'maitrise-ouvrage-privee': 'Maîtrise d\'ouvrage privée',
  'maitrise-ouvrage-publique': 'Maîtrise d\'ouvrage publique',
  'mentions-legales': 'Mentions légales',
  'politique-confidentialite': 'Politique de confidentialité',
};
const segs = pageSource.split('/').filter(Boolean);
let pageLabel = pageName;
if (!pageLabel) {
  if (segs.length === 0) pageLabel = 'Accueil';
  else pageLabel = segs.map((s) => SEG[s] || (s.charAt(0).toUpperCase() + s.slice(1))).join(' — ');
}
const emailSubject = `Formulaire Façades Haut-Doubs — page : ${pageLabel}`;
---

<section id="devis" class="form-section">
  <div class="container">
    <div class="form-wrapper">
      <div class="form-intro">
        <h2>{titre}</h2>
        <p>{sousTitre}</p>
        <ul class="form-bullets">
          <li>✓ Étude personnalisée et gratuite</li>
          <li>✓ Visite technique sur place</li>
          <li>✓ Devis détaillé sous 48h</li>
          <li>✓ Réponse sous 24h ouvrées</li>
        </ul>
      </div>

      <form
        class="form"
        name="devis"
        method="POST"
        action="/devis-envoye/"
        enctype="multipart/form-data"
        data-netlify="true"
        data-netlify-honeypot="bot-field"
      >
        <input type="hidden" name="form-name" value="devis" />
        <input type="hidden" name="page_source" value={pageSource} />
        <input type="hidden" name="page_origine" value={pageLabel} />
        <input type="hidden" name="subject" value={emailSubject} />
        <p class="hidden">
          <label>Ne pas remplir : <input name="bot-field" /></label>
        </p>

        <div class="row">
          <div class="field">
            <label for="prenom">Prénom *</label>
            <input type="text" id="prenom" name="prenom" required />
          </div>
          <div class="field">
            <label for="nom">Nom *</label>
            <input type="text" id="nom" name="nom" required />
          </div>
        </div>

        <div class="row">
          <div class="field">
            <label for="email">Email *</label>
            <input type="email" id="email" name="email" required />
          </div>
          <div class="field">
            <label for="telephone">Téléphone *</label>
            <input type="tel" id="telephone" name="telephone" required />
          </div>
        </div>

        <div class="field">
          <label for="adresse">Adresse du chantier *</label>
          <input type="text" id="adresse" name="adresse" required placeholder="N° et rue (ex : 12 Rue Gay Lussac)" />
        </div>

        <div class="row">
          <div class="field">
            <label for="code_postal">Code postal *</label>
            <input type="text" id="code_postal" name="code_postal" required pattern="[0-9]{5}" />
          </div>
          <div class="field">
            <label for="ville">Ville *</label>
            <input type="text" id="ville" name="ville" required />
          </div>
        </div>

        <div class="field">
          <label for="message">Votre projet *</label>
          <textarea id="message" name="message" rows="4" required placeholder="Décrivez votre projet (type de travaux, surface approximative, délai souhaité...)"></textarea>
        </div>

        <div class="field field-file">
          <label for="fichiers">Photos ou plans <span class="opt">(facultatif)</span></label>
          <input
            type="file"
            id="fichiers"
            name="fichiers"
            multiple
            accept=".jpg,.jpeg,.png,.heic,.pdf"
          />
          <span class="file-hint">Jusqu'à 5 fichiers · 8 Mo max chacun · JPG, PNG, HEIC ou PDF</span>
        </div>

        <button type="submit" class="btn submit-btn">Envoyer ma demande</button>

        <p class="rgpd">
          Vos données sont uniquement utilisées pour vous recontacter dans le cadre de votre demande.
        </p>
      </form>
    </div>
  </div>
</section>

<style>
  .form-section {
    background: linear-gradient(135deg, var(--orange-100) 0%, #FCEFE8 100%);
    padding: 100px 0;
  }

  .form-wrapper {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 60px;
    align-items: center;
    background: white;
    border-radius: 16px;
    padding: 50px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
  }
  @media (max-width: 900px) {
    .form-wrapper { grid-template-columns: 1fr; gap: 30px; padding: 30px; }
  }

  .form-intro h2 { margin-bottom: 14px; }
  .form-intro p {
    color: var(--anthracite);
    margin-bottom: 24px;
  }
  .form-bullets {
    list-style: none;
  }
  .form-bullets li {
    color: var(--noir-doux);
    padding: 8px 0;
    font-weight: 500;
  }

  .form .row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 16px;
  }
  @media (max-width: 540px) {
    .form .row { grid-template-columns: 1fr; }
  }

  .field {
    display: flex;
    flex-direction: column;
    margin-bottom: 16px;
  }
  .field label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--anthracite);
    margin-bottom: 6px;
  }
  .field input,
  .field textarea {
    font-family: var(--font-corps);
    font-size: 0.95rem;
    padding: 12px 14px;
    border: 1px solid var(--gris-perle);
    border-radius: 6px;
    background: var(--blanc-casse);
    transition: border-color 0.2s, background 0.2s;
  }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--orange-500);
    background: white;
    box-shadow: 0 0 0 3px rgba(210, 106, 71, 0.15);
  }

  .submit-btn {
    width: 100%;
    padding: 16px;
    font-size: 1.05rem;
    margin-top: 8px;
  }

  .rgpd {
    font-size: 0.8rem;
    color: var(--gris-moyen);
    text-align: center;
    margin-top: 16px;
    margin-bottom: 0;
  }

  .hidden { display: none; }

  /* Champ fichiers */
  .field-file .opt {
    color: var(--gris-moyen);
    font-weight: 400;
  }
  .field-file input[type="file"] {
    padding: 10px 14px;
    font-size: 0.9rem;
    cursor: pointer;
  }
  .field-file input[type="file"]::file-selector-button {
    font-family: var(--font-corps);
    font-weight: 600;
    font-size: 0.85rem;
    background: var(--orange-100);
    color: var(--orange-700);
    border: none;
    border-radius: 6px;
    padding: 8px 14px;
    margin-right: 12px;
    cursor: pointer;
    transition: background 0.2s;
  }
  .field-file input[type="file"]::file-selector-button:hover {
    background: var(--orange-300);
  }
  .file-hint {
    font-size: 0.78rem;
    color: var(--gris-moyen);
    margin-top: 6px;
  }
  .file-error {
    font-size: 0.82rem;
    color: var(--erreur);
    font-weight: 600;
    margin-top: 6px;
    display: none;
  }
  .file-error.show { display: block; }
</style>

<script>
  // Validation côté client : max 5 fichiers, 8 Mo chacun
  const MAX_FILES = 5;
  const MAX_SIZE = 8 * 1024 * 1024; // 8 Mo

  document.querySelectorAll('input[type="file"][name="fichiers"]').forEach((input) => {
    const el = input as HTMLInputElement;
    // Crée le message d'erreur juste après le hint
    const hint = el.parentElement?.querySelector('.file-hint');
    const err = document.createElement('span');
    err.className = 'file-error';
    hint?.after(err);

    el.addEventListener('change', () => {
      err.classList.remove('show');
      const files = Array.from(el.files || []);
      if (files.length > MAX_FILES) {
        err.textContent = `Maximum ${MAX_FILES} fichiers. Vous en avez sélectionné ${files.length}.`;
        err.classList.add('show');
        el.value = '';
        return;
      }
      const tropGros = files.find((f) => f.size > MAX_SIZE);
      if (tropGros) {
        err.textContent = `« ${tropGros.name} » dépasse 8 Mo. Merci de réduire sa taille.`;
        err.classList.add('show');
        el.value = '';
      }
    });
  });
</script>
