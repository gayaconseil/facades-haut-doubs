---
interface Props {
  titre: string;
  description: string;
  iconeUrl: string;
  href: string;
  badgeRge?: boolean;
}

const { titre, description, iconeUrl, href, badgeRge = false } = Astro.props;
---

<a href={href} class="bloc-metier">
  <div class="icone-wrapper">
    <div
      class="bloc-icone"
      style={`-webkit-mask-image: url('${iconeUrl}'); mask-image: url('${iconeUrl}');`}
      role="img"
      aria-label={titre}
    ></div>
    {badgeRge && <span class="badge-rge" aria-label="Certifié RGE">RGE</span>}
  </div>
  <h3>{titre}</h3>
  <p>{description}</p>
  <span class="lire-plus">En savoir plus →</span>
</a>

<style>
  .bloc-metier {
    display: block;
    background: white;
    border: 1px solid var(--gris-perle);
    border-radius: 10px;
    padding: 30px 24px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    height: 100%;
  }
  .bloc-metier:hover {
    transform: translateY(-4px);
    border-color: var(--orange-300);
    box-shadow: 0 12px 32px rgba(210, 106, 71, 0.12);
  }

  .icone-wrapper {
    position: relative;
    width: 80px;
    height: 80px;
    margin-bottom: 20px;
  }
  .bloc-icone {
    width: 100%;
    height: 100%;
    background-color: var(--orange-500);
    -webkit-mask-size: contain;
    mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    transition: background-color 0.2s;
  }
  .bloc-metier:hover .bloc-icone {
    background-color: var(--orange-700);
  }

  /* Tampon RGE style "encreur" bleu marine, positionné en haut à gauche */
  .badge-rge {
    position: absolute;
    top: -4px;
    left: -8px;
    background: #1a3a6b;
    color: white;
    font-family: 'Courier New', 'Courier', monospace;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 1.5px;
    padding: 3px 7px;
    border: 2px solid #1a3a6b;
    border-radius: 3px;
    transform: rotate(-4deg);
    box-shadow: 0 1px 3px rgba(26, 58, 107, 0.3);
    text-transform: uppercase;
    line-height: 1;
  }

  .bloc-metier h3 {
    color: var(--noir-doux);
    margin-bottom: 10px;
    font-size: 1.3rem;
  }
  .bloc-metier p {
    color: var(--anthracite);
    font-size: 0.95rem;
    margin-bottom: 16px;
    line-height: 1.55;
  }
  .lire-plus {
    color: var(--orange-700);
    font-weight: 600;
    font-size: 0.9rem;
  }
</style>
