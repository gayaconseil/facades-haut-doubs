---
interface Props {
  titre: string;
  description: string;
  iconeUrl: string;
  href: string;
}

const { titre, description, iconeUrl, href } = Astro.props;
---

<a href={href} class="bloc-metier">
  <div
    class="bloc-icone"
    style={`-webkit-mask-image: url('${iconeUrl}'); mask-image: url('${iconeUrl}');`}
    role="img"
    aria-label={titre}
  ></div>
  <h3>{titre}</h3>
  <p>{description}</p>
  <span class="lire-plus">En savoir plus →</span>
</a>

<style>
  .bloc-metier {
    display: block;
    background: white;
    border: 1px solid var(--gris-perle);
    border-radius: 10px;
    padding: 30px 24px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    height: 100%;
  }
  .bloc-metier:hover {
    transform: translateY(-4px);
    border-color: var(--orange-300);
    box-shadow: 0 12px 32px rgba(210, 106, 71, 0.12);
  }

  .bloc-icone {
    width: 80px;
    height: 80px;
    margin-bottom: 20px;
    background-color: var(--orange-500);
    -webkit-mask-size: contain;
    mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    transition: background-color 0.2s;
  }
  .bloc-metier:hover .bloc-icone {
    background-color: var(--orange-700);
  }

  .bloc-metier h3 {
    color: var(--noir-doux);
    margin-bottom: 10px;
    font-size: 1.3rem;
  }
  .bloc-metier p {
    color: var(--anthracite);
    font-size: 0.95rem;
    margin-bottom: 16px;
    line-height: 1.55;
  }
  .lire-plus {
    color: var(--orange-700);
    font-weight: 600;
    font-size: 0.9rem;
  }
</style>
