---
import BaseLayout from '../layouts/BaseLayout.astro';
import FormDevis from '../components/FormDevis.astro';

const projets = [
  // ITE
  { titre: 'Isolation thermique extérieure', lieu: 'Cernay-l\'Église', metier: 'ITE', image: '/photos-chantiers/ite-cernay-1.jpg' },
  { titre: 'Isolation thermique extérieure', lieu: 'Vallerot-lès-Belvoir', metier: 'ITE', image: '/photos-chantiers/ite-vallerot-1.jpg' },
  { titre: 'ITE maison individuelle', lieu: 'Gilley', metier: 'ITE', image: '/photos-chantiers/ite-gilley.jpg' },
  { titre: 'ITE immeuble collectif', lieu: 'Maîche', metier: 'ITE', image: '/photos-chantiers/ite-maiche-2.jpg' },
  // Ravalement
  { titre: 'Ravalement de façade (D3 armé)', lieu: 'Pontarlier', metier: 'Ravalement', image: '/photos-chantiers/ravalement-pontarlier-1.jpg' },
  { titre: 'Ravalement maison récente', lieu: 'Houtaud', metier: 'Ravalement', image: '/photos-chantiers/ravalement-houtaud.jpg' },
  { titre: 'Ravalement de façade', lieu: 'Gilley', metier: 'Ravalement', image: '/photos-chantiers/ravalement-gilley.jpg' },
  // Enduit chaux
  { titre: 'Enduit à la chaux — presbytère', lieu: 'Levier', metier: 'Enduit', image: '/photos-chantiers/enduit-levier-1.jpg' },
  { titre: 'Enduit chaux traditionnel', lieu: 'Mouthier-Haute-Pierre', metier: 'Enduit', image: '/photos-chantiers/enduit-mouthier-1.jpg' },
  // Joint de pierre
  { titre: 'Joint de pierre — ferme comtoise', lieu: 'Lavans-Vuillafans', metier: 'Joint de pierre', image: '/photos-chantiers/joint-pierre-lavans-1.jpg' },
  // Bardage
  { titre: 'Bardage — bâtiment public', lieu: 'La Chênalotte', metier: 'Bardage', image: '/photos-chantiers/bardage-chenalotte-1.jpg' },
  { titre: 'ITE bâtiment collectif', lieu: 'Maîche', metier: 'ITE', image: '/photos-chantiers/ite-maiche-3.jpg' },
];
---

<BaseLayout
  title="Nos références — Façades Haut-Doubs"
  description="Découvrez nos réalisations de façades dans le Haut-Doubs : ravalement, bardage, ITE, enduit, étanchéité. Pontarlier, Morteau, Valdahon."
>
  <section class="hero-ref">
    <div class="container">
      <h1>Nos <em>références</em></h1>
      <p class="lead">
        Voici quelques-unes de nos réalisations dans le Haut-Doubs et ses environs.
        <strong>2 000+ chantiers</strong> réussis en 18 ans pour des particuliers et professionnels.
      </p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-title">
        <h2>Une sélection de <em>nos chantiers</em></h2>
        <p>Tous les corps de métiers représentés : ravalement, bardage, ITE, enduit.</p>
      </div>
      <div class="projets-grid">
        {projets.map((p) => (
          <div class="projet-card">
            <div class="projet-img" style={`background-image: url('${p.image}')`}>
              <span class="projet-tag">{p.metier}</span>
            </div>
            <div class="projet-info">
              <h3>{p.titre}</h3>
              <p>📍 {p.lieu}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="gris">
    <div class="container">
      <div class="section-title">
        <h2>Vos <em>avis comptent</em></h2>
        <p>Note moyenne de nos clients : <strong>4,7/5</strong></p>
      </div>
      <div class="temoignages-grid">
        <div class="temoignage">
          <div class="stars">★★★★★</div>
          <p>
            « Travail soigné, équipe sympathique, respect des délais. Notre façade est comme
            neuve, nous sommes ravis. »
          </p>
          <div class="signature">— Famille L., Pontarlier</div>
        </div>
        <div class="temoignage">
          <div class="stars">★★★★★</div>
          <p>
            « Conseil de qualité dès la visite technique. ITE parfaitement réalisée, nos
            factures de chauffage ont baissé de 25%. »
          </p>
          <div class="signature">— M. et Mme D., Valdahon</div>
        </div>
        <div class="temoignage">
          <div class="stars">★★★★★</div>
          <p>
            « Bardage bois magnifique sur notre rénovation. Travail impeccable, équipe
            professionnelle et à l'écoute. »
          </p>
          <div class="signature">— P. Barbier, Morteau</div>
        </div>
      </div>
      <p class="note">Témoignages à compléter par de vrais avis clients après lancement.</p>
    </div>
  </section>

  <FormDevis />
</BaseLayout>

<style>
  .hero-ref {
    background: linear-gradient(135deg, var(--orange-100) 0%, #FCEFE8 100%);
    padding: 80px 0 60px;
    text-align: center;
  }
  .hero-ref h1 { font-size: clamp(2.5rem, 5vw, 4rem); margin-bottom: 16px; }
  .hero-ref h1 em { color: var(--orange-500); font-style: normal; }
  .hero-ref .lead { font-size: 1.2rem; color: var(--anthracite); max-width: 800px; margin: 0 auto; }

  .projets-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  @media (max-width: 900px) { .projets-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 540px) { .projets-grid { grid-template-columns: 1fr; } }
  .projet-card {
    background: white;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .projet-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.12);
  }
  .projet-img {
    aspect-ratio: 4/3;
    background-size: cover;
    background-position: center;
    position: relative;
  }
  .projet-tag {
    position: absolute;
    top: 12px;
    right: 12px;
    background: var(--orange-500);
    color: white;
    padding: 6px 14px;
    border-radius: 50px;
    font-size: 0.78rem;
    font-weight: 600;
  }
  .projet-info { padding: 18px 20px; }
  .projet-info h3 {
    font-size: 1.15rem;
    color: var(--noir-doux);
    margin-bottom: 6px;
  }
  .projet-info p { color: var(--anthracite); font-size: 0.9rem; margin: 0; }

  .temoignages-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 1100px;
    margin: 0 auto 30px;
  }
  @media (max-width: 900px) { .temoignages-grid { grid-template-columns: 1fr; } }
  .temoignage {
    background: white;
    padding: 30px;
    border-radius: 10px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.05);
  }
  .stars {
    color: var(--orange-500);
    font-size: 1.2rem;
    margin-bottom: 14px;
  }
  .temoignage p {
    font-style: italic;
    color: var(--anthracite);
    margin-bottom: 14px;
    line-height: 1.5;
  }
  .signature {
    color: var(--orange-700);
    font-weight: 600;
    font-size: 0.9rem;
  }
  .note {
    text-align: center;
    color: var(--gris-moyen);
    font-style: italic;
    font-size: 0.85rem;
  }
</style>
