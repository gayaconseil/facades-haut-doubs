---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import FormDevis from '../../components/FormDevis.astro';

const problemes = [
  { texte: 'Infiltrations d\'eau dans le balcon', icone: '💧' },
  { texte: 'Terrasse fissurée ou décollée', icone: '⚡' },
  { texte: 'Escaliers extérieurs glissants', icone: '🪜' },
  { texte: 'Dommages dus au gel', icone: '🥶' },
  { texte: 'Stagnation d\'eau en surface', icone: '🌧️' },
  { texte: 'Joints de carrelage dégradés', icone: '🧱' },
];

// ⚠️ NOTE INTERNE : 3 solutions proposées en attente de validation
// par Matéo Riva (Façades Bisontines). À ajuster selon ses préconisations
// techniques officielles pour balcons / terrasses / escaliers.
const solutions = [
  {
    titre: 'Étanchéité PMMA (balcons)',
    description: 'Résine méthacrylate à polymérisation rapide, adaptée aux balcons. Souple, résistante aux variations thermiques importantes du Haut-Doubs, polymérisation en quelques heures.',
    applications: 'Balcons, petites surfaces, zones exposées au gel',
    image: '/photos-fb/facades-bisontines-etancheite-balcon-03.jpg',
  },
  {
    titre: 'Résine époxy armée (terrasses)',
    description: 'Système d\'étanchéité liquide avec armature en fibre de verre, particulièrement adapté aux grandes surfaces planes. Excellente résistance mécanique et étanchéité durable.',
    applications: 'Terrasses, toitures-terrasses, espaces extérieurs accessibles',
    image: '/photos-fb/facades-bisontines-chantier-etancheite-sol-1.jpg',
  },
  {
    titre: 'Système SEL polyuréthane (escaliers)',
    description: 'Système d\'Étanchéité Liquide à base de polyuréthane, avec finition antidérapante. Souple, idéal pour les marches et nez d\'escaliers extérieurs.',
    applications: 'Escaliers extérieurs, marches, paliers, accès en pente',
    image: '/photos-fb/facades-bisontines-chantier-etancheite-sol-2.jpg',
  },
];

const faq = [
  {
    q: 'Comment savoir si mon balcon ou ma terrasse a besoin d\'une étanchéité ?',
    r: 'Plusieurs signaux : taches d\'humidité au plafond du dessous, mousses ou décollements en surface, eau qui stagne après une pluie, joints ou carrelage qui se dégradent. Un diagnostic technique gratuit lève le doute.',
  },
  {
    q: 'Combien de temps dure une étanchéité de sol ?',
    r: 'Une étanchéité liquide bien posée tient 20 à 30 ans selon le système et l\'exposition. Tous nos systèmes bénéficient d\'une garantie décennale.',
  },
  {
    q: 'L\'étanchéité est-elle garantie ?',
    r: 'Oui, garantie décennale sur l\'ensemble de nos systèmes. Notre certification RGE Qualibat est votre assurance qualité.',
  },
  {
    q: 'Peut-on conserver l\'aspect d\'origine du balcon ou de la terrasse ?',
    r: 'Oui : nos résines existent dans une large gamme de teintes et de finitions (lisse, sablée, antidérapante). Vous pouvez même les recouvrir d\'un nouveau carrelage si vous le souhaitez.',
  },
];
---

<BaseLayout
  title="Étanchéité de sol dans le Haut-Doubs — Façades Haut-Doubs"
  description="Solutions d'étanchéité de sol dans le Haut-Doubs : balcons, terrasses, escaliers. Pontarlier, Morteau, Valdahon. Garantie décennale, RGE Qualibat."
>
  <Hero
    titre="Étanchéité de sol <em>balcons, terrasses, escaliers</em>"
    sousTitre="Protégez vos espaces extérieurs des infiltrations et du gel. Solutions techniques durables, garantie décennale, expert du Haut-Doubs."
    bgImage="/photos-fb/facades-bisontines-etancheite-sol-exterieur.jpg"
  />

  <section>
    <div class="container intro-grid">
      <div>
        <h2>Protéger vos sols <em>extérieurs</em></h2>
        <p>
          L'<strong>étanchéité de sol</strong> traite et prévient les
          <strong>infiltrations d'eau</strong> sur vos surfaces horizontales :
          balcons, terrasses, escaliers extérieurs et toitures-terrasses.
        </p>
        <p>
          Dans le <strong>Haut-Doubs</strong>, où les pluies abondantes, le gel
          et les écarts thermiques sollicitent fortement vos sols extérieurs,
          une étanchéité professionnelle est essentielle pour préserver durablement
          votre patrimoine.
        </p>
        <p>
          Nous proposons <strong>3 solutions techniques</strong> selon votre problématique :
          l'étanchéité de vos balcons, de vos terrasses et de vos escaliers, avec une
          <strong>garantie décennale</strong> sur l'ensemble de nos systèmes.
        </p>
      </div>
      <div>
        <img
          src="/photos-fb/facades-bisontines-chantier-etancheite-sol-2.jpg"
          alt="Étanchéité de sol en cours de réalisation"
          class="intro-img"
        />
      </div>
    </div>
  </section>

  <section class="gris">
    <div class="container">
      <div class="section-title">
        <h2>6 signaux d'<em>alerte humidité</em></h2>
        <p>Si vous reconnaissez l'un de ces signes, une étude technique s'impose.</p>
      </div>
      <div class="problems-grid">
        {problemes.map((p) => (
          <div class="prob-card">
            <span class="prob-icone">{p.icone}</span>
            <span>{p.texte}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-title">
        <h2>Nos 3 solutions <em>techniques</em></h2>
        <p>Une solution adaptée à chaque type de support : balcons, terrasses, escaliers.</p>
      </div>
      <div class="solutions-grid">
        {solutions.map((s) => (
          <div class="solution-card">
            <div class="sol-img" style={`background-image: url('${s.image}')`}></div>
            <div class="sol-body">
              <h3>{s.titre}</h3>
              <p>{s.description}</p>
              <div class="sol-meta">
                <strong>Applications :</strong> {s.applications}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="gris">
    <div class="container">
      <div class="section-title">
        <h2>Questions <em>fréquentes</em></h2>
      </div>
      <div class="faq">
        {faq.map((item) => (
          <details class="faq-item">
            <summary>{item.q}</summary>
            <p>{item.r}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <FormDevis
    titre="Un balcon, une terrasse, un escalier à étancher ?"
    sousTitre="Décrivez-nous votre problème, nous effectuons un diagnostic gratuit et proposons la solution technique adaptée."
  />
</BaseLayout>

<style>
  .intro-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 50px;
    align-items: center;
  }
  @media (max-width: 900px) { .intro-grid { grid-template-columns: 1fr; } }
  .intro-grid h2 em { color: var(--orange-500); font-style: normal; }
  .intro-grid p { color: var(--anthracite); margin-bottom: 16px; font-size: 1.05rem; line-height: 1.65; }
  .intro-img { width: 100%; border-radius: 12px; aspect-ratio: 4/3; object-fit: cover; box-shadow: 0 12px 40px rgba(0,0,0,0.1); }

  .problems-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    max-width: 1000px;
    margin: 0 auto;
  }
  @media (max-width: 700px) { .problems-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 460px) { .problems-grid { grid-template-columns: 1fr; } }
  .prob-card {
    background: white;
    border: 1px solid var(--gris-perle);
    border-left: 4px solid var(--orange-500);
    border-radius: 8px;
    padding: 18px 20px;
    display: flex;
    align-items: center;
    gap: 14px;
    color: var(--noir-doux);
    font-weight: 500;
  }
  .prob-icone { font-size: 1.8rem; flex-shrink: 0; }

  .solutions-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  @media (max-width: 900px) { .solutions-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 600px) { .solutions-grid { grid-template-columns: 1fr; } }
  .solution-card { background: white; border-radius: 12px; overflow: hidden; border: 1px solid var(--gris-perle); box-shadow: 0 4px 16px rgba(0,0,0,0.05); }
  .sol-img { aspect-ratio: 16/9; background-size: cover; background-position: center; }
  .sol-body { padding: 24px; }
  .sol-body h3 { color: var(--noir-doux); margin-bottom: 10px; font-size: 1.2rem; }
  .sol-body p { color: var(--anthracite); margin-bottom: 14px; line-height: 1.5; font-size: 0.95rem; }
  .sol-meta {
    color: var(--anthracite);
    font-size: 0.88rem;
    background: var(--gris-fond);
    padding: 10px 14px;
    border-radius: 6px;
  }
  .sol-meta strong { color: var(--orange-700); }

  .faq { max-width: 800px; margin: 0 auto; }
  .faq-item { background: white; border: 1px solid var(--gris-perle); border-radius: 8px; margin-bottom: 12px; }
  .faq-item summary {
    padding: 18px 22px;
    font-family: var(--font-titre);
    font-size: 1.1rem;
    color: var(--noir-doux);
    cursor: pointer;
    list-style: none;
    position: relative;
    padding-right: 50px;
  }
  .faq-item summary::after { content: '+'; position: absolute; right: 22px; top: 50%; transform: translateY(-50%); color: var(--orange-500); font-size: 1.5rem; }
  .faq-item[open] summary::after { content: '−'; }
  .faq-item p { padding: 0 22px 20px; color: var(--anthracite); margin: 0; }
</style>
