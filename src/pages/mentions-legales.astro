<style>
  .legal {
    padding-top: 60px;
    padding-bottom: 60px;
  }
  .legal h1 {
    margin-bottom: 8px;
  }
  .legal .updated {
    color: var(--anthracite);
    font-size: 0.9rem;
    margin-bottom: 40px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--gris-perle);
  }
  .legal h2 {
    color: var(--orange-700);
    font-size: 1.4rem;
    margin-top: 36px;
    margin-bottom: 16px;
  }
  .legal p,
  .legal ul {
    margin-bottom: 16px;
    color: var(--anthracite);
    max-width: 780px;
  }
  .legal ul {
    padding-left: 24px;
  }
  .legal ul li {
    margin-bottom: 8px;
  }
  .legal a {
    color: var(--orange-700);
    font-weight: 500;
  }
  .legal em {
    background: var(--orange-100);
    padding: 2px 6px;
    border-radius: 3px;
    font-style: normal;
    color: var(--orange-700);
    font-size: 0.9em;
  }
</style>
